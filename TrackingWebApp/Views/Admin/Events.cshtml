    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model List<TrackingWebApp.Entities.TrackingEvent>
@{
    ViewData["Title"] = "Admin - Events";
}

<div class="page-wrap">
    <div class="card card-soft p-4 mb-3">
        <h1>Tracking Events</h1>
        <p class="text-muted mb-0">
            Denne side viser events der er modtaget af Tracking API’et og gemt i databasen.
        </p>
    </div>

    <div class="card card-soft p-3">
        @if (Model == null || Model.Count == 0)
        {
            <p class="text-muted mb-0">Der er ingen events endnu. Gå til forsiden og klik lidt rundt.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Path</th>
                            <th>Element</th>
                            <th>Session</th>
                            <th>Timestamp (UTC)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model)
                        {
                            <tr>
                                <td>@e.EventType</td>
                                <td>@e.Path</td>
                                <td>@(e.ElementId ?? "-")</td>
                                <td style="max-width: 260px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @(e.SessionId ?? "-")
                                </td>
                                <td>@e.TimestampUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>