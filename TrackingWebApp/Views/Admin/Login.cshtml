@{
    ViewData["Title"] = "Admin Login";
}

<div class="page-wrap">
    <div class="card card-soft p-4" style="max-width: 520px; margin: 0 auto;">
        <h1 class="mb-2">Admin login</h1>
        <p class="text-muted">Log ind for at se tracking-data.</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mt-3">@ViewBag.Error</div>
        }

        <form method="post" class="mt-3">
            <div class="mb-3">
                <label class="form-label">Brugernavn</label>
                <input name="username" class="form-control" autocomplete="username" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input name="password" type="password" class="form-control" autocomplete="current-password" />
            </div>

            <button class="btn btn-accent w-100" type="submit">Log ind</button>
        </form>
    </div>
</div>
