@model TrackingWebApp.ViewModels.AdminStatsViewModel

@{
    ViewData["Title"] = "Admin - Statistik";
}


<div class="page-wrap">
    <div class="card card-soft p-4 mb-3">
        <h1>Statistik</h1>
        <p class="text-muted mb-0">
            Overblik over tracking-data: mest besøgte sider, mest klikkede elementer og top sessions.
        </p>
    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-6">
            <div class="card card-soft p-3">
                <h5 class="mb-3">Mest besøgte sider (pageviews)</h5>

                @if (Model.TopPages.Count == 0)
                {
                    <p class="text-muted mb-0">Ingen data endnu.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>Path</th>
                                    <th class="text-end">Antal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.TopPages)
                                {
                                    <tr>
                                        <td>@p.Path</td>
                                        <td class="text-end">@p.Count</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card card-soft p-3">
                <h5 class="mb-3">Mest klikkede elementer</h5>

                @if (Model.TopClicks.Count == 0)
                {
                    <p class="text-muted mb-0">Ingen data endnu.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>ElementId</th>
                                    <th class="text-end">Antal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.TopClicks)
                                {
                                    <tr>
                                        <td>@c.ElementId</td>
                                        <td class="text-end">@c.Count</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="col-12">
            <div class="card card-soft p-3">
                <h5 class="mb-3">Top sessions (flest events)</h5>

                @if (Model.TopSessions.Count == 0)
                {
                    <p class="text-muted mb-0">Ingen data endnu.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>SessionId</th>
                                    <th class="text-end">Antal events</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.TopSessions)
                                {
                                    <tr>
                                        <td style="max-width: 520px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                            @s.SessionId
                                        </td>
                                        <td class="text-end">@s.Count</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Aktivitet over tid</h5>
        <canvas id="eventsChart" height="90"></canvas>
    </div>
</div>

<form method="get" class="mb-3 d-flex gap-2 align-items-center">
    <label class="form-label mb-0">Vis data for:</label>

    <select name="days" class="form-select" style="max-width: 180px;" onchange="this.form.submit()">
        <option value="1" selected="@(Model.Days == 1)">Sidste 24 timer</option>
        <option value="7" selected="@(Model.Days == 7)">7 dage</option>
        <option value="15" selected="@(Model.Days == 15)">15 dage</option>
        <option value="30" selected="@(Model.Days == 30)">30 dage</option>
    </select>
</form>

<form asp-action="ClearAllTrackingData" method="post" class="mt-3"
      onsubmit="return confirm('Er du sikker? Dette sletter ALT tracking-data!');">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">
        Ryd alt tracking-data
    </button>
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const raw = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySeries));

        // Find alle datoer i perioden (unik)
        const labels = [...new Set(raw.map(x => x.Date.substring(0, 10)))];

        function countFor(date, type) {
            const item = raw.find(x => x.Date.substring(0, 10) === date && x.EventType === type);
            return item ? item.Count : 0;
        }

        const pageviews = labels.map(d => countFor(d, "pageview"));
        const clicks = labels.map(d => countFor(d, "click"));

        const ctx = document.getElementById('eventsChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels,
                datasets: [
                    { label: 'Pageviews', data: pageviews, tension: 0.25 },
                    { label: 'Clicks', data: clicks, tension: 0.25 }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: true } },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    </script>
}
