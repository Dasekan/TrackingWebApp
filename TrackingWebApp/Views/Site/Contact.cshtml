@{
    ViewData["Title"] = "Kontakt";
}

<div class="page-wrap">
    <div class="card card-soft p-4 mb-3">
        <h1>Kontakt</h1>
        <p class="text-muted mb-0">Skriv en kort besked, så vender vi tilbage.</p>
    </div>

    <div class="card card-soft p-4">
        <form>
            <div class="mb-3">
                <label class="form-label">Navn</label>
                <input class="form-control" placeholder="Dit navn" />
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input class="form-control" placeholder="din@email.dk" />
            </div>
            <div class="mb-3">
                <label class="form-label">Besked</label>
                <textarea class="form-control" rows="5" placeholder="Hvad kan vi hjælpe med?"></textarea>
            </div>

            <button type="button" class="btn btn-accent track-click" data-track="contact_submit">
                Send besked
            </button>
        </form>

        <p class="text-muted mt-3 mb-0">
            (Denne formular sender ikke rigtigt endnu — den er til demo og tracking.)
        </p>
    </div>
</div>
