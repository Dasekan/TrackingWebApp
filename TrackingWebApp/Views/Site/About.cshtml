@{
    ViewData["Title"] = "Om Qistal";
}

<div class="page-wrap">
    <div class="card card-soft p-4">
        <h1>Om os</h1>
        <p class="text-muted">
            Qistal er et lille team, der bygger systemer i .NET med fokus på struktur, drift og målbarhed.
            Vi tror på, at gode løsninger både skal fungere – og kunne forbedres ud fra data.
        </p>

        <div class="mt-3 d-flex gap-2 flex-wrap">
            <a class="btn btn-accent track-click" data-track="about_cta_contact"
               asp-controller="Site" asp-action="Contact">Kontakt os</a>
            <a class="btn btn-accent track-click" data-track="about_cta_services"
               asp-controller="Site" asp-action="Services">Se services</a>
        </div>
    </div>
</div>
